{
  "name": "pitchside",
  "productName": "PitchSide",
  "version": "1.0.0",
  "upgrade": "pear://yfpjeh7orukksxgedgpqyuj335zsra3emqusazegrm7na78h855o",
  "description": "Offline, P2P AI football watch-party. Serverless mesh (Pears) + on-device AI commentary (QVAC).",
  "license": "MIT",
  "author": "",
  "type": "commonjs",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "lint": "prettier --check . && lunte",
    "format": "prettier --write . && lunte --fix",
    "build:wallet": "esbuild renderer/wallet.js --bundle --format=esm --platform=browser --alias:sodium-native=./renderer/.stubs/sodium-native.js --inject:./renderer/.stubs/buffer-shim.js --define:global=globalThis --outfile=renderer/wallet.bundle.js",
    "prestart": "npm run build:wallet",
    "start": "electron-forge start -- --no-updates",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "test": "node --test --test-force-exit 'test/**/*.test.js'",
    "test:contracts": "npm --prefix contracts test"
  },
  "dependencies": {
    "@qvac/llm-llamacpp": "^0.31.0",
    "@tetherto/wdk-wallet-evm": "^1.0.0-beta.15",
    "b4a": "^1.8.1",
    "bare": "^1.30.2",
    "buffer": "^6.0.3",
    "corestore": "^7.9.1",
    "framed-stream": "^1.0.1",
    "graceful-goodbye": "^1.3.3",
    "hypercore": "^11.33.5",
    "hypercore-crypto": "^3.7.0",
    "hyperswarm": "^4.17.0",
    "paparam": "^1.10.0",
    "pear-runtime": "^1.1.4",
    "which-runtime": "^1.3.2"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-msix": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "app-builder-lib": "^26.8.1",
    "electron": "^40.2.1",
    "electron-forge-plugin-prune-prebuilds": "^1.0.0",
    "electron-forge-plugin-universal-prebuilds": "^1.0.0",
    "esbuild": "^0.28.1",
    "lunte": "^1.6.0",
    "pear-electron-forge-maker-appimage": "^2.0.0",
    "pear-electron-forge-maker-flatpak": "^0.0.6",
    "pear-electron-forge-maker-snap": "^0.0.10",
    "prettier": "^3.8.1",
    "prettier-config-holepunch": "^2.0.0"
  },
  "optionalDependencies": {
    "@qvac/bare-sdk": "^0.14.1"
  }
}
